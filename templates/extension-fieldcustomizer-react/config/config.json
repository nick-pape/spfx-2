{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "<%= componentName.kebab %>-field-customizer": {
      "components": [
        {
          "entrypoint": "./lib/extensions/<%= componentName.camel %>/<%= componentName.pascal %>FieldCustomizer.js",
          "manifest": "./src/extensions/<%= componentName.camel %>/<%= componentName.pascal %>FieldCustomizer.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "<%= componentName.pascal %>FieldCustomizerStrings": "lib/extensions/<%= componentName.camel %>/loc/{locale}.js"
  }
}
