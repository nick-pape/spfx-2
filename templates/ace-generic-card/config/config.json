{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "<%= componentNameHyphenCase %>-adaptive-card-extension": {
      "components": [
        {
          "entrypoint": "./lib/adaptiveCardExtensions/<%= componentNameCamelCase %>/<%= componentNameCapitalCase %>AdaptiveCardExtension.js",
          "manifest": "./src/adaptiveCardExtensions/<%= componentNameCamelCase %>/<%= componentNameCapitalCase %>AdaptiveCardExtension.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "<%= componentNameCapitalCase %>AdaptiveCardExtensionStrings": "lib/adaptiveCardExtensions/<%= componentNameCamelCase %>/loc/{locale}.js"
  }
}
