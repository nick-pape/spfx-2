{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "<%= componentName.kebab %>-library": {
      "components": [
        {
          "entrypoint": "./lib/libraries/<%= componentName.camel %>/<%= componentName.pascal %>Library.js",
          "manifest": "./src/libraries/<%= componentName.camel %>/<%= componentName.pascal %>Library.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "<%= componentName.pascal %>LibraryStrings": "lib/libraries/<%= componentName.camel %>/loc/{locale}.js"
  }
}
