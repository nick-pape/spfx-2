{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "<%= componentNameHyphenCase %>-library": {
      "components": [
        {
          "entrypoint": "./lib/libraries/<%= componentNameCamelCase %>/<%= componentNameCapitalCase %>Library.js",
          "manifest": "./src/libraries/<%= componentNameCamelCase %>/<%= componentNameCapitalCase %>Library.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "<%= componentNameCapitalCase %>LibraryStrings": "lib/libraries/<%= componentNameCamelCase %>/loc/{locale}.js"
  }
}
