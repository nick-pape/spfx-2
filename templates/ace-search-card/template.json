  "contextSchema": {
    "libraryName": {
      "type": "string",
      "description": "The library name for the component"
    },
    "componentId": {
      "type": "string",
      "description": "The unique ID for the component"
    },
    "solutionId": {
      "type": "string",
      "description": "The unique ID for the solution"
    },
    "featureId": {
      "type": "string",
      "description": "The unique ID for the feature"
