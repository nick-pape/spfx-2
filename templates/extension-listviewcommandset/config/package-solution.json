{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/package-solution.schema.json",
  "solution": {
    "name": "<%= libraryName %>-client-side-solution",
    "id": "<%= solutionId %>",
    "version": "1.0.0.0",
    "includeClientSideAssets": true,
    "skipFeatureDeployment": true,
    "isDomainIsolated": false,
    "developer": {
      "name": "",
      "websiteUrl": "",
      "privacyUrl": "",
      "termsOfUseUrl": "",
      "mpnId": "Undefined-1.22.2"
    },
    "metadata": {
      "shortDescription": {
        "default": "<%= componentDescription %>"
      },
      "longDescription": {
        "default": "<%= componentDescription %>"
      },
      "screenshotPaths": [],
      "videoUrl": "",
      "categories": []
    },
    "features": [
      {
        "title": "List View Command Set - Deployment of list view commands",
        "description": "Deploys a List View Command Set associated with a SharePoint list view",
        "id": "<%= featureId %>",
        "version": "1.0.0.0"
      }
    ]
  },
  "paths": {
    "zippedPackage": "solution/<%= libraryName %>.sppkg"
  }
}
