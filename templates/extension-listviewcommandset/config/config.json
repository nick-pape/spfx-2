{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "<%= componentNameHyphenCase %>-command-set": {
      "components": [
        {
          "entrypoint": "./lib/extensions/<%= componentNameCamelCase %>CommandSet/<%= componentNameCapitalCase %>CommandSet.js",
          "manifest": "./src/extensions/<%= componentNameCamelCase %>CommandSet/<%= componentNameCapitalCase %>CommandSet.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "<%= componentNameCapitalCase %>CommandSetStrings": "lib/extensions/<%= componentNameCamelCase %>CommandSet/loc/{locale}.js"
  }
}
