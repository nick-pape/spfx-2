{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "<%= componentName.kebab %>-command-set": {
      "components": [
        {
          "entrypoint": "./lib/extensions/<%= componentName.camel %>CommandSet/<%= componentName.pascal %>CommandSet.js",
          "manifest": "./src/extensions/<%= componentName.camel %>CommandSet/<%= componentName.pascal %>CommandSet.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "<%= componentName.pascal %>CommandSetStrings": "lib/extensions/<%= componentName.camel %>CommandSet/loc/{locale}.js"
  }
}
