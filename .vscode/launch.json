{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Selected Test File",
			"cwd": "${fileDirname}",
			"runtimeArgs": [
				"--nolazy",
				"--inspect-brk",
				"${workspaceFolder}/tools/spfx-cli-build-rig/node_modules/@rushstack/heft/bin/heft",
				"--debug",
				"test",
				"--test-path-pattern",
        "${fileBasenameNoExtension}"
			],
			"skipFiles": ["<node_internals>/**"],
			"outFiles": [],
			"sourceMaps": true,
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen"
		},
		{
			"name": "Attach",
			"type": "node",
			"request": "attach",
			"port": 9229,
			"outFiles": []
		}
	]
}
